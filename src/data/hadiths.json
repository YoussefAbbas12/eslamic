{
  "categories": [
    {
      "id": "faith",
      "name": "الإيمان والعقيدة",
      "icon": "🕌",
      "hadiths": [
        {
          "id": 1,
          "arabic": "الإيمان بضع وسبعون شعبة، أعلاها قول لا إله إلا الله، وأدناها إماطة الأذى عن الطريق، والحياء شعبة من الإيمان",
          "narrator": "أبو هريرة",
          "source": "صحيح مسلم",
          "topic": "شعب الإيمان"
        },
        {
          "id": 2,
          "arabic": "لا يؤمن أحدكم حتى أكون أحب إليه من والده وولده والناس أجمعين",
          "narrator": "أنس بن مالك",
          "source": "صحيح البخاري",
          "topic": "محبة الرسول"
        },
        {
          "id": 3,
          "arabic": "من كان آخر كلامه لا إله إلا الله دخل الجنة",
          "narrator": "معاذ بن جبل",
          "source": "سنن أبي داود",
          "topic": "فضل التوحيد"
        }
      ]
    },
    {
      "id": "prayer",
      "name": "الصلاة",
      "icon": "🤲",
      "hadiths": [
        {
          "id": 1,
          "arabic": "الصلاة نور، والصدقة برهان، والصبر ضياء، والقرآن حجة لك أو عليك",
          "narrator": "أبو مالك الأشعري",
          "source": "صحيح مسلم",
          "topic": "فضل الصلاة"
        },
        {
          "id": 2,
          "arabic": "من صلى البردين دخل الجنة",
          "narrator": "أبو موسى الأشعري",
          "source": "صحيح البخاري",
          "topic": "الفجر والعصر"
        },
        {
          "id": 3,
          "arabic": "بين الرجل وبين الشرك والكفر ترك الصلاة",
          "narrator": "جابر بن عبدالله",
          "source": "صحيح مسلم",
          "topic": "أهمية الصلاة"
        },
        {
          "id": 4,
          "arabic": "أول ما يحاسب به العبد يوم القيامة الصلاة، فإن صلحت صلح سائر عمله، وإن فسدت فسد سائر عمله",
          "narrator": "أبو هريرة",
          "source": "سنن الترمذي",
          "topic": "الصلاة أول ما يحاسب عليه"
        }
      ]
    },
    {
      "id": "morals",
      "name": "الأخلاق والآداب",
      "icon": "✨",
      "hadiths": [
        {
          "id": 1,
          "arabic": "إنما بعثت لأتمم مكارم الأخلاق",
          "narrator": "أبو هريرة",
          "source": "مسند أحمد",
          "topic": "مكارم الأخلاق"
        },
        {
          "id": 2,
          "arabic": "أكمل المؤمنين إيماناً أحسنهم خلقاً",
          "narrator": "أبو هريرة",
          "source": "سنن الترمذي",
          "topic": "حسن الخلق"
        },
        {
          "id": 3,
          "arabic": "المؤمن من أمنه الناس على دمائهم وأموالهم",
          "narrator": "أنس بن مالك",
          "source": "سنن الترمذي",
          "topic": "الأمانة"
        },
        {
          "id": 4,
          "arabic": "من كان يؤمن بالله واليوم الآخر فليقل خيراً أو ليصمت",
          "narrator": "أبو هريرة",
          "source": "صحيح البخاري",
          "topic": "آداب الكلام"
        },
        {
          "id": 5,
          "arabic": "لا يحل لمسلم أن يهجر أخاه فوق ثلاث ليال، يلتقيان فيعرض هذا ويعرض هذا، وخيرهما الذي يبدأ بالسلام",
          "narrator": "أبو أيوب الأنصاري",
          "source": "صحيح البخاري",
          "topic": "الهجر"
        }
      ]
    },
    {
      "id": "knowledge",
      "name": "العلم والتعلم",
      "icon": "📚",
      "hadiths": [
        {
          "id": 1,
          "arabic": "طلب العلم فريضة على كل مسلم",
          "narrator": "أنس بن مالك",
          "source": "سنن ابن ماجه",
          "topic": "فضل طلب العلم"
        },
        {
          "id": 2,
          "arabic": "من سلك طريقاً يلتمس فيه علماً سهل الله له به طريقاً إلى الجنة",
          "narrator": "أبو هريرة",
          "source": "صحيح مسلم",
          "topic": "ثواب طلب العلم"
        },
        {
          "id": 3,
          "arabic": "إن الملائكة لتضع أجنحتها لطالب العلم رضاً بما يصنع",
          "narrator": "أبو الدرداء",
          "source": "سنن أبي داود",
          "topic": "فضل طالب العلم"
        }
      ]
    },
    {
      "id": "family",
      "name": "الأسرة والأرحام",
      "icon": "👨‍👩‍👧‍👦",
      "hadiths": [
        {
          "id": 1,
          "arabic": "رضا الرب في رضا الوالد، وسخط الرب في سخط الوالد",
          "narrator": "عبدالله بن عمرو",
          "source": "سنن الترمذي",
          "topic": "بر الوالدين"
        },
        {
          "id": 2,
          "arabic": "من أحب أن يبسط له في رزقه وينسأ له في أثره فليصل رحمه",
          "narrator": "أنس بن مالك",
          "source": "صحيح البخاري",
          "topic": "صلة الرحم"
        },
        {
          "id": 3,
          "arabic": "خيركم خيركم لأهله، وأنا خيركم لأهلي",
          "narrator": "عائشة",
          "source": "سنن الترمذي",
          "topic": "حسن معاملة الأهل"
        },
        {
          "id": 4,
          "arabic": "استوصوا بالنساء خيراً",
          "narrator": "أبو هريرة",
          "source": "صحيح البخاري",
          "topic": "الوصية بالنساء"
        }
      ]
    },
    {
      "id": "charity",
      "name": "الصدقة والإحسان",
      "icon": "💝",
      "hadiths": [
        {
          "id": 1,
          "arabic": "الصدقة تطفئ الخطيئة كما يطفئ الماء النار",
          "narrator": "معاذ بن جبل",
          "source": "سنن الترمذي",
          "topic": "فضل الصدقة"
        },
        {
          "id": 2,
          "arabic": "اتقوا النار ولو بشق تمرة",
          "narrator": "عدي بن حاتم",
          "source": "صحيح البخاري",
          "topic": "الصدقة ولو بالقليل"
        },
        {
          "id": 3,
          "arabic": "تبسمك في وجه أخيك صدقة",
          "narrator": "أبو ذر الغفاري",
          "source": "سنن الترمذي",
          "topic": "الابتسامة صدقة"
        },
        {
          "id": 4,
          "arabic": "إذا مات الإنسان انقطع عنه عمله إلا من ثلاثة: صدقة جارية، أو علم ينتفع به، أو ولد صالح يدعو له",
          "narrator": "أبو هريرة",
          "source": "صحيح مسلم",
          "topic": "الصدقة الجارية"
        }
      ]
    },
    {
      "id": "patience",
      "name": "الصبر والابتلاء",
      "icon": "💪",
      "hadiths": [
        {
          "id": 1,
          "arabic": "ما يصيب المسلم من نصب ولا وصب ولا هم ولا حزن ولا أذى ولا غم، حتى الشوكة يشاكها، إلا كفر الله بها من خطاياه",
          "narrator": "أبو سعيد الخدري وأبو هريرة",
          "source": "صحيح البخاري",
          "topic": "الابتلاء كفارة"
        },
        {
          "id": 2,
          "arabic": "عجباً لأمر المؤمن إن أمره كله له خير، وليس ذلك لأحد إلا للمؤمن، إن أصابته سراء شكر فكان خيراً له، وإن أصابته ضراء صبر فكان خيراً له",
          "narrator": "صهيب",
          "source": "صحيح مسلم",
          "topic": "الشكر والصبر"
        },
        {
          "id": 3,
          "arabic": "من يرد الله به خيراً يصب منه",
          "narrator": "أبو هريرة",
          "source": "صحيح البخاري",
          "topic": "الابتلاء علامة خير"
        }
      ]
    },
    {
      "id": "quran",
      "name": "القرآن الكريم",
      "icon": "📖",
      "hadiths": [
        {
          "id": 1,
          "arabic": "خيركم من تعلم القرآن وعلمه",
          "narrator": "عثمان بن عفان",
          "source": "صحيح البخاري",
          "topic": "فضل تعلم القرآن"
        },
        {
          "id": 2,
          "arabic": "اقرؤوا القرآن فإنه يأتي يوم القيامة شفيعاً لأصحابه",
          "narrator": "أبو أمامة الباهلي",
          "source": "صحيح مسلم",
          "topic": "القرآن شفيع"
        },
        {
          "id": 3,
          "arabic": "الماهر بالقرآن مع السفرة الكرام البررة، والذي يقرأ القرآن ويتتعتع فيه وهو عليه شاق له أجران",
          "narrator": "عائشة",
          "source": "صحيح البخاري",
          "topic": "أجر قراءة القرآن"
        }
      ]
    },
    {
      "id": "remembrance",
      "name": "الذكر والدعاء",
      "icon": "🤲",
      "hadiths": [
        {
          "id": 1,
          "arabic": "من قال سبحان الله وبحمده في يوم مائة مرة حطت خطاياه وإن كانت مثل زبد البحر",
          "narrator": "أبو هريرة",
          "source": "صحيح البخاري",
          "topic": "فضل التسبيح"
        },
        {
          "id": 2,
          "arabic": "الدعاء هو العبادة",
          "narrator": "النعمان بن بشير",
          "source": "سنن الترمذي",
          "topic": "أهمية الدعاء"
        },
        {
          "id": 3,
          "arabic": "ليس شيء أكرم على الله من الدعاء",
          "narrator": "أبو هريرة",
          "source": "سنن الترمذي",
          "topic": "فضل الدعاء"
        }
      ]
    },
    {
      "id": "afterlife",
      "name": "الآخرة والجنة",
      "icon": "🌟",
      "hadiths": [
        {
          "id": 1,
          "arabic": "في الجنة ما لا عين رأت، ولا أذن سمعت، ولا خطر على قلب بشر",
          "narrator": "أبو هريرة",
          "source": "صحيح البخاري",
          "topic": "نعيم الجنة"
        },
        {
          "id": 2,
          "arabic": "من قال لا إله إلا الله وحده لا شريك له، له الملك وله الحمد، وهو على كل شيء قدير، في يوم مائة مرة كانت له عدل عشر رقاب، وكتبت له مائة حسنة، ومحيت عنه مائة سيئة، وكانت له حرزاً من الشيطان يومه ذلك حتى يمسي",
          "narrator": "أبو هريرة",
          "source": "صحيح البخاري",
          "topic": "فضل التهليل"
        }
      ]
    }
  ]
}
